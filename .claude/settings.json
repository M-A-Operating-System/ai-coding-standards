{
  "permissions": {
    "allow": [
      "Bash(python scripts/*.py *)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(pip install *)"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(git reset --hard*)",
      "Bash(git rebase*)",
      "Bash(rm -rf*)",
      "Bash(git commit --amend*)"
    ]
  }
}
